<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time Since"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/row1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <View
            android:id="@+id/accent1"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="#FF7C3AED" />

        <TextView
            android:id="@+id/title1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/elapsed1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF9E9E9E"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/row2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <View
            android:id="@+id/accent2"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="#FF7C3AED" />

        <TextView
            android:id="@+id/title2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/elapsed2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF9E9E9E"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/row3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <View
            android:id="@+id/accent3"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="#FF7C3AED" />

        <TextView
            android:id="@+id/title3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/elapsed3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF9E9E9E"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No events yet"
        android:textColor="#FF757575"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
